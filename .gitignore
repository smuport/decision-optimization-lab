# OS
.DS_Store

# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
coverage/
.turbo/
.nx/

# Environment
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

