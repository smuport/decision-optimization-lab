# OS
.DS_Store

# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
out-tsc/
coverage/
.turbo/
.nx/
.angular/
frontend/.angular/
*.tsbuildinfo

# Environment
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# Codex local runtime files
.codex/cache/
.codex/tmp/
.codex/*.local.toml
.local/

# Local runtime storage
storage/submissions/*
storage/results/*
backend/storage/submissions/*
backend/storage/results/*
submission-service/storage/*
!storage/submissions/.gitkeep
!storage/results/.gitkeep
!backend/storage/submissions/.gitkeep
!backend/storage/results/.gitkeep
!submission-service/storage/.gitkeep

# Prisma local database snapshots
*.db
*.db-journal
